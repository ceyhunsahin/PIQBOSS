{
  "expo": {
    "name": "PiqBoss",
    "slug": "piqboss",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "piqboss",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.piqsoft.boss",
      "googleServicesFile": "./GoogleService-Info.plist",
      "entitlements": {
        "aps-environment": "development"
      },
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.piqpos.boss",
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "color": "#0047AB"
        }
      ]
    ],
    "extra": {
      "apiUrl": "http://192.168.1.10:80",
      "eas": {
        "projectId": "7134f944-b22e-474f-94c5-50c4d38758e5"
      }
    },
    "owner": "ceyhun2086"
  }
}
